# --- Supabase (client-side; safe to ship — protected by Row Level Security) ---
# Used by the browser to read/write project data and authenticate users.
# Set these in Cloudflare Pages project settings for production builds.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_PUBLISHABLE_OR_ANON_KEY"

# GEMINI_API_KEY is NOT a frontend variable. The AI advisor runs as a Supabase
# Edge Function (supabase/functions/advisor); set the key as a function secret:
#   supabase secrets set GEMINI_API_KEY=...
# Without it, the advisor returns a graceful fallback response.
