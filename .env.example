# GEMINI_API_KEY: Required for Gemini AI API calls (server-side advisor).
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# --- Supabase (client-side; safe to ship — protected by Row Level Security) ---
# Used by the browser to read/write project data and authenticate users.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_PUBLISHABLE_OR_ANON_KEY"
